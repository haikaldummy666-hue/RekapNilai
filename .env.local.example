# Environment Variables Template untuk AI OCR Scanning System

# ==============================================================================
# Google Vision API - REQUIRED untuk production OCR
# ==============================================================================
# Dapatkan API key dari: https://console.cloud.google.com
# 1. Create Google Cloud Project
# 2. Enable Cloud Vision API
# 3. Create Service Account
# 4. Generate JSON key file
# 5. Extract 'private_key' dan 'client_email' values

GOOGLE_VISION_API_KEY=your_google_vision_api_key_here
GOOGLE_VISION_PROJECT_ID=your_google_cloud_project_id

# ==============================================================================
# Supabase Configuration - REQUIRED
# ==============================================================================
# Sudah ada, pastikan sudah set dengan nilai correct

VITE_SUPABASE_URL=your_supabase_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# ==============================================================================
# OCR Scanning Configuration - OPTIONAL
# ==============================================================================

# Use mock OCR untuk development/testing (jika tidak punya API key)
# Set ke 'true' jika ingin use mock data, 'false' atau kosong untuk real API
VITE_USE_MOCK_OCR=false

# Minimum confidence threshold untuk data dianggap valid (0-100)
# Default: 70
OCR_MIN_CONFIDENCE_THRESHOLD=70

# Enable automatic anomaly detection
# Default: true
VITE_ENABLE_ANOMALY_DETECTION=true

# Enable logging untuk semua scanning transactions
# Default: true
VITE_ENABLE_SCANNING_LOGS=true

# ==============================================================================
# Backup Configuration - OPTIONAL
# ==============================================================================

# Enable automatic backup sebelum applying OCR data
# Default: true
VITE_AUTO_BACKUP_ENABLED=true

# Backup retention period dalam hari (default: 90)
VITE_BACKUP_RETENTION_DAYS=90

# ==============================================================================
# Validation Configuration - OPTIONAL
# ==============================================================================

# Required fields untuk validation (comma-separated)
# Default: nisn,nama,jenisKelamin,tanggalLahir
VITE_REQUIRED_FIELDS=nisn,nama,jenisKelamin,tanggalLahir

# Nilai range untuk validation (min-max)
# Default: 0-100
OCR_VALUE_MIN_RANGE=0
OCR_VALUE_MAX_RANGE=100

# ==============================================================================
# Feature Flags - OPTIONAL
# ==============================================================================

# Enable scanning feature
VITE_ENABLE_SCANNING=true

# Enable scanning history/logs viewer
VITE_ENABLE_SCANNING_HISTORY=true

# Enable manual review interface
VITE_ENABLE_MANUAL_REVIEW=true

# Enable rollback functionality
VITE_ENABLE_ROLLBACK=true

# ==============================================================================
# Notification Configuration - OPTIONAL
# ==============================================================================

# Email notifications on scanning complete
VITE_ENABLE_EMAIL_NOTIFICATIONS=false
SMTP_SERVER=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# ==============================================================================
# Development Configuration
# ==============================================================================

# Enable verbose logging (development only)
VITE_DEBUG_OCR=false

# Log OCR results to console (development only)
VITE_LOG_OCR_RESULTS=false

# Simulate OCR processing delay (ms)
OCR_MOCK_DELAY=2000

# ==============================================================================
# NOTE: Jangan commit file .env.local ke git!
# Tambahkan .env.local ke .gitignore
# ==============================================================================
